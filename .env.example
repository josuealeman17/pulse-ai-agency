# ─────────────────────────────────────────────────────────────
# Pulse — environment variables (TEMPLATE)
# Copy to .env and fill in real values. NEVER put real keys in this file —
# .env.example is committed to git; .env is gitignored.
# ─────────────────────────────────────────────────────────────

# --- Anthropic (Claude Haiku 4.5) — REQUIRED for chat ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Supabase ---
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional + review emails) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Until you verify a sending domain, the sandbox sender only reaches your own inbox.
RESEND_FROM=Pulse <onboarding@resend.dev>

# --- Cal.com (appointment booking) ---
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxx
CALCOM_BASE_URL=https://api.cal.com/v2
# Default event type used by the demo/fallback; real clients store their own in the DB.
CALCOM_EVENT_TYPE_ID=
CALCOM_TIMEZONE=America/Denver
CALCOM_SLOTS_VERSION=2024-09-04
CALCOM_BOOKINGS_VERSION=2024-08-13

# --- API server ---
PORT=8787
# Comma-separated origins allowed to call the API (client sites). Use * for local dev only.
ALLOWED_ORIGINS=*
# Optional shared secret to protect the follow-up cron endpoint.
CRON_SECRET=

# --- Public URLs (used in emails / widget links) ---
PUBLIC_API_URL=http://localhost:8787
PUBLIC_WIDGET_URL=http://localhost:5173
